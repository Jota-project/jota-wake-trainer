# Config local — API keys, URLs privadas, nunca al repo
configs.local/

# Datos de audio — demasiado grandes para git
data/positivos/
data/sintetizados/
data/negativos/

# Entorno virtual
.venv/
venv/
__pycache__/
*.pyc

# Piper binario y modelos de voz (descarga única local)
piper/

# Datasets de openWakeWord (descarga automática ~2-4 GB)
openWakeWord/datasets/

# Artefactos temporales de entrenamiento
output/*.ckpt
output/*.pt
output/logs/

# El modelo .tflite final SÍ se versiona (es pequeño, ~5 KB)
!models/*.tflite

# macOS
.DS_Store

# Datos de audio de proyectos (mismo criterio que data/ raíz)
projects/*/data/positivos/
projects/*/data/sintetizados/
projects/*/data/negativos/

# Artefactos de entrenamiento por proyecto
projects/*/output/

# El modelo .tflite SÍ se versiona
!projects/*/models/*.tflite
