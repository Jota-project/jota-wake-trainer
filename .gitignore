# Config local — API keys, URLs privadas, nunca al repo
configs.local/

# Config local de providers TTS (contiene referencias a API keys — no versionar)
configs/providers.local.json

# Datos de audio — demasiado grandes para git
data/positivos/
data/sintetizados/
data/negativos/

# Audio de referencia para clonado de voz (XTTS) — datos personales/biométricos,
# de terceros en el caso de Magarma (notas de voz de WhatsApp). No se versiona
# bajo ningún concepto: es voz real de personas identificables, no algo que
# deba vivir en un repo aunque sea privado o de una organización.
data/referencia_voz_sito/
data/referencia_voz_magarma/
data/referencia_voz_*/

# Datasets de ruido/RIR descargados de HuggingFace para la augmentación
# (grandes y regenerables — ver trainer/noise_data.py)
data/background_noise/
data/rir/

# Entorno virtual
.venv/
venv/
.venv-clone/
__pycache__/
*.pyc

# Piper binario y modelos de voz (descarga única local)
piper/

# Datasets de openWakeWord (descarga automática ~2-4 GB)
openWakeWord/datasets/

# Artefactos temporales de entrenamiento
output/*.ckpt
output/*.pt
output/logs/

# Negativos precalculados descargados de HuggingFace (~200 MB - 17 GB, cacheados)
data/negative_features/

# Directorio de trabajo del entrenamiento (features .npy intermedias, grandes)
models/_work/
projects/*/models/_work/

# El modelo .onnx intermedio no se versiona, el .tflite final SÍ (es pequeño, ~5 KB)
models/*.onnx
projects/*/models/*.onnx
!models/*.tflite

# Build artifacts
*.egg-info/
dist/
build/

# macOS
.DS_Store

# Superpowers brainstorming sessions
.superpowers/

# Datos de audio de proyectos (mismo criterio que data/ raíz)
projects/*/data/positivos/
projects/*/data/sintetizados/
projects/*/data/negativos/

# Artefactos de entrenamiento por proyecto
projects/*/output/

# El modelo .tflite SÍ se versiona
!projects/*/models/*.tflite
